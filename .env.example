# Provider de LLM usado na classificacao/correcao: anthropic (default) ou deepseek
CNPJSCAN_PROVIDER=anthropic

# Chave da API da Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Chave da API da DeepSeek (https://platform.deepseek.com/) — so' se usar --provider deepseek
DEEPSEEK_API_KEY=sk-...

# Opcional: sobrescreve o modelo do provider escolhido.
# Anthropic (default): claude-opus-4-8 | claude-sonnet-5 | claude-haiku-4-5
# DeepSeek  (default): deepseek-chat   | deepseek-reasoner
CNPJSCAN_MODEL=claude-opus-4-8
